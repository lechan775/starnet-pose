        <mxCell id="summary_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;strokeWidth=1.5;arcSize=10;fontFamily=Arial;fontSize=13;align=left;spacingLeft=14;" value="&lt;b&gt;Architecture&lt;/b&gt;&lt;br/&gt;base_dim = 32&lt;br/&gt;depths = [2, 2, 8, 4]&lt;br/&gt;out_indices = (3,)&lt;br/&gt;ca_stages = [2, 3]&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Per-stage output shapes for 256 x 192 input&lt;/b&gt;&lt;br/&gt;Stem: 32 x 128 x 96&lt;br/&gt;Stage 0: 32 x 64 x 48&lt;br/&gt;Stage 1: 64 x 32 x 24&lt;br/&gt;Stage 2: 128 x 16 x 12&lt;br/&gt;Stage 3: 256 x 8 x 6" vertex="1">
          <mxGeometry x="1190" y="520" width="480" height="180" as="geometry" />
        </mxCell>
        <mxCell id="summary_box2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;arcSize=10;fontFamily=Arial;fontSize=13;align=left;spacingLeft=14;" value="&lt;b&gt;How to read the backbone correctly&lt;/b&gt;&lt;br/&gt;1. It is a hierarchical encoder, not a decoder.&lt;br/&gt;2. Resolution decreases stage by stage.&lt;br/&gt;3. Coordinate Attention in Stage 2 and Stage 3 does not change shape.&lt;br/&gt;4. Because only Stage 3 is exported, the head receives a single low-resolution feature map." vertex="1">
          <mxGeometry x="1730" y="520" width="580" height="180" as="geometry" />
        </mxCell>

