        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontFamily=Arial;fontColor=#444444;" value="Backbone only. This page shows the downsampling encoder path inside StarNetCA, not the RTMCC head." vertex="1">
          <mxGeometry x="560" y="56" width="1280" height="22" as="geometry" />
        </mxCell>
        <mxCell id="top_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;arcSize=10;fontFamily=Arial;fontSize=12;" value="&lt;b&gt;Key point&lt;/b&gt;&lt;br/&gt;Inside the backbone there is only progressive downsampling: /2 -&amp;gt; /4 -&amp;gt; /8 -&amp;gt; /16 -&amp;gt; /32.&lt;br/&gt;No neck, no FPN, no upsampling, no pyramid fusion." vertex="1">
